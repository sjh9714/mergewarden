{
  "name": "mergewarden",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "description": "Checkout-free policy scanning for AI-generated GitHub pull requests",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sjh9714/mergewarden.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/sjh9714/mergewarden#readme",
  "bugs": {
    "url": "https://github.com/sjh9714/mergewarden/issues"
  },
  "keywords": [
    "coding-agents",
    "ai-code-review",
    "github-actions",
    "devsecops",
    "supply-chain-security",
    "ci-cd"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "mergewarden": "./dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:pack": "pnpm build && node scripts/package-smoke.mjs",
    "test:packed": "node scripts/package-smoke.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@mergewarden/core": "workspace:*",
    "@mergewarden/github": "workspace:*"
  }
}
